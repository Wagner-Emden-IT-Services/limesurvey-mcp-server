LIMESURVEY_URL=https://survey.example.com/index.php/admin/remotecontrol
LIMESURVEY_USERNAME=rpc-user
LIMESURVEY_PASSWORD=replace-me
LIMESURVEY_AUTH_PLUGIN=Authdb
LIMESURVEY_TIMEOUT_MS=30000
LIMESURVEY_MAX_RESPONSE_CHARS=50000
LIMESURVEY_READ_ONLY=false
LIMESURVEY_EXPORT_DIR=./exports
LIMESURVEY_MAX_EXPORT_BYTES=104857600
LIMESURVEY_THEME_DIR=./themes
LIMESURVEY_MAX_THEME_ASSET_BYTES=5242880
# Enables the non-standard list_response_exports method only when the matching LimeSurvey extension is installed.
LIMESURVEY_ENABLE_EXPERIMENTAL_METHODS=false
# Set to true only for a trusted development instance using plain HTTP.
LIMESURVEY_ALLOW_INSECURE_HTTP=false

# stdio is the secure default for a local MCP client. Use http for remote/container operation.
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
# Required for non-loopback HTTP bindings.
MCP_HTTP_BEARER_TOKEN=
# Comma-separated exact values. Configure both when exposing HTTP through a reverse proxy or browser.
MCP_HTTP_ALLOWED_HOSTS=
MCP_HTTP_ALLOWED_ORIGINS=
